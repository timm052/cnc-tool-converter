{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.cnctoolconverter.app",
  "productName": "CNC Tool Converter",
  "version": "1.0.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["hsmlib"],
        "name": "HSM Tool Library",
        "description": "Fusion 360 / Inventor CAM Tool Library"
      },
      {
        "ext": ["tbl", "tool"],
        "name": "LinuxCNC Tool Table",
        "description": "LinuxCNC Tool Table"
      },
      {
        "ext": ["ofs"],
        "name": "HAAS Offset Table",
        "description": "HAAS Offset / Tool Table"
      },
      {
        "ext": ["vkb"],
        "name": "RhinoCAM Tool Library",
        "description": "RhinoCAM / VisualMill Tool Library"
      }
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.sectigo.com",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "providerShortName": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "publisher": "CNC Tool Converter Contributors",
    "copyright": "Copyright © 2024–2026 CNC Tool Converter Contributors",
    "shortDescription": "Convert CNC tool libraries between CAM formats",
    "longDescription": "CNC Tool Converter converts tool library files between Fusion 360, LinuxCNC, HAAS, Fanuc, Mach3, RhinoCAM and other CAM/CNC formats. Includes a persistent tool library, job lists, work offset sheets, and F&S calculations."
  },
  "app": {
    "windows": [
      {
        "title": "CNC Tool Converter",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:cnc-tool-converter.db"]
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/cnc-tool-converter/cnc-tool-converter/releases/latest/download/latest.json"
      ]
    }
  }
}
