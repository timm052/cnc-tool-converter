    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "dexie": "^4.3.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.446.0",
    "qrcode": "^1.5.4",
